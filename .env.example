# MongoDB connection used by the Next.js route handlers.
MONGODB_URI=mongodb://127.0.0.1:27017/marker

# Canonical public origin used to reject cross-origin mutations in production.
APP_ORIGIN=https://marker.example.com

# Explicit account promoted by the one-time P0 auth migration.
ADMIN_BOOTSTRAP_EMAIL=bagratgharibjanyan8@gmail.com

# Swagger UI is disabled by default in production.
ENABLE_API_DOCS=false


# Structured JSON log metadata and minimum emitted severity.
SERVICE_NAME=marker-web
LOG_LEVEL=info

# MongoDB readiness probe timeout, clamped to 250-10000 milliseconds.
HEALTHCHECK_TIMEOUT_MS=2000
# Only enable when the deployment proxy overwrites client forwarding headers.
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_HOPS=0